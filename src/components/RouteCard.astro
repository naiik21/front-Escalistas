---
import type { Ruta } from '../data/rutas';
import { difficultyColor } from '../data/rutas';

interface Props {
  ruta: Ruta;
}
const { ruta } = Astro.props;

const color = difficultyColor[ruta.difficulty] ?? { bg: '#FFFFFF15', text: '#FFFFFF' };
const dateFormatted = new Date(ruta.date).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' });
---
<a href={`/rutas/${ruta.slug}`} class="card">
  <div class="card__img" style={`background-image: url('${ruta.image}')`}></div>

  <div class="card__body">
    <div class="card__top">
      <span class="card__badge" style={`background: ${color.bg}; color: ${color.text};`}>
        {ruta.difficulty.charAt(0).toUpperCase() + ruta.difficulty.slice(1)}
      </span>
      <span class="card__date">{dateFormatted}</span>
    </div>

    <h2 class="card__title">{ruta.title}</h2>

    <div class="card__zone">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
      {ruta.zone}
    </div>

    <div class="card__stats">
      <span class="card__stat">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14l4 4-4 4"/></svg>
        {ruta.distance_km} km
      </span>
      <span class="card__stat">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
        {ruta.elevation_gain.toLocaleString('es-ES')} m
      </span>
      <span class="card__stat card__stat--muted">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        {ruta.duration}
      </span>
    </div>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--card);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 4px 24px #00000008;
    transition: transform 0.2s, box-shadow 0.2s;
    color: var(--text-1);
  }
  .card:hover { transform: translateY(-3px); box-shadow: 0 8px 32px #00000012; }

  .card__img {
    width: 100%;
    height: 180px;
    background-size: cover;
    background-position: center;
    transition: transform 0.4s ease;
  }
  .card:hover .card__img { transform: scale(1.03); }

  .card__body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 14px 18px 18px;
  }

  .card__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card__badge {
    padding: 3px 8px;
    border-radius: 5px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3px;
  }

  .card__date { font-size: 11px; color: var(--text-3); }

  .card__title {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--text-1);
  }

  .card__zone {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    color: var(--text-3);
  }
  .card__zone svg { flex-shrink: 0; }

  .card__stats {
    display: flex;
    gap: 14px;
    padding-top: 6px;
    border-top: 1px solid var(--border);
    margin-top: 2px;
  }

  .card__stat {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-2);
  }
  .card__stat svg { color: var(--sage); flex-shrink: 0; }
  .card__stat--muted svg { color: var(--text-3); }
</style>
